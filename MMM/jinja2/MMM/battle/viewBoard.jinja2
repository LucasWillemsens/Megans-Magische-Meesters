{% extends 'base.jinja2' %}

{% block content %}
<div class="playerScreen playingCards fourColours rotateHand">
    <div class="players">
        <div class="title">
            <h1>{{ game.title }}</h1>
            <p>Round {{ game.roundNumber }}</p>
        </div>
        <div class="playerInfo">
            <h2>{{ player.name }}</h2>
            {% if player.profilePictureSource == "" %}
            <img draggable="false" class="fit-picture" src="{{ static('profile.jpg')}}" alt="{{player.name}}'s profile picture" />
            {% else %}
            <img draggable="false" class="fit-picture" src="{{ static('{{assetsDir}}+{{player.profilePictureSource}}')}}"
                alt="{{player.name}}'s profile picture" />
            {% endif %}
        </div>
    </div>

    {% if error_message != "" %}
    <div class="cards">
        <p><b>Action error:</b> {{ error_message }}</p>
    </div>
    {% endif %}

    {% if enemyBoards %}
    <ul class="enemyBoards basic-mat table">
        {% for enemy in enemyBoards %}
        <li class="enemyBoard">
            <h2>{{ enemy.participant.player.name }} </h2>
            {# gameBoard #}
            <p class="cardType">Deck: {{ enemy.deckCount }} | Hand: {{ enemy.handCount }}</p>
            <ul class="lanes">
                {% for lane in enemy.laneRows %}
                <li class="lane {{lane.name}}">
                    <ul class="cardRow" title="cards">
                        {% for card in lane.cards %}
                            <li class="card smallCard">
                                {% if card.card.artSource == "" %}
                                <img draggable="false" class="fit-picture" src="{{ static('1flubeltje.jpg')}}" alt="no art of {{card.card.title}}" />
                                {% else %}
                                <img draggable="false" class="fit-picture" src="{{ static(card.card.artSource)}}" alt="art of {{card.card.title}}" />
                                {% endif %}
                            
                                <div class="smallCardInfo">
                                    {# <a href="{{returnURL}}card/{{ card.id }}/"> #}
                                        <p>
                                            {{ card.card.title }}
                                        </p>
                                        {#
                                    </a> #}
                                    <p class="cardType">
                                        {{["Intelligence","Speed","Visciousness","Resolve"][card.card.cardType]}}
                                    </p>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                    <p> {{ lane.name }} </p>
                    <ul class="cardRow" title="trustedCards">
                        {% for card in lane.trustedCards %}
                            <li class="card smallCard">
                                {% if card.card.artSource == "" %}
                                <img draggable="false" class="fit-picture" src="{{ static('1flubeltje.jpg')}}" alt="no art of {{card.card.title}}" />
                                {% else %}
                                <img draggable="false" class="fit-picture" src="{{ static(card.card.artSource)}}" alt="art of {{card.card.title}}" />
                                {% endif %}
                            
                                <div class="smallCardInfo">
                                    {# <a href="{{returnURL}}card/{{ card.id }}/"> #}
                                        <p>
                                            {{ card.card.title }}
                                        </p>
                                        {#
                                    </a> #}
                                    <p class="cardType">
                                        {{["Intelligence","Speed","Visciousness","Resolve"][card.card.cardType]}}
                                    </p>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </li>
                {% endfor %}
                </ul>
            <div class="smallCardInfo">
            
            </div>
        </li>
        {% endfor %}
        </ul>
        {% else %}
        <p>No enemy participants loaded yet.</p>
        {% endif %}

    <ul class="basic-mat table">
        <li class="playerBoard ">
            <h2> {{ player.name }} </h2>
            {# gameBoard #}
            <ul class="lanes">
                {% for lane in ownLaneRows %}
                <li class="lane {{lane.name}}">
                    <ul class="cardRow" title="cards">
                        {% for card in lane.cards %}
                            <li class="card smallCard">
                                {% if card.card.artSource == "" %}
                                <img draggable="false" class="fit-picture" src="{{ static('1flubeltje.jpg')}}" alt="no art of {{card.card.title}}" />
                                {% else %}
                                <img draggable="false" class="fit-picture" src="{{ static(card.card.artSource)}}" alt="art of {{card.card.title}}" />
                                {% endif %}
                            
                                <div class="smallCardInfo">
                                    {# <a href="{{returnURL}}card/{{ card.id }}/"> #}
                                        <p>
                                            {{ card.card.title }}
                                        </p>
                                        {#
                                    </a> #}
                                    <p class="cardType">
                                        {{["Intelligence","Speed","Visciousness","Resolve"][card.card.cardType]}}
                                    </p>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                    <p> {{ lane.name }} </p>
                    <ul class="cardRow" title="trustedCards">
                        {% for card in lane.trustedCards %}
                            <li class="card smallCard">
                                {% if card.card.artSource == "" %}
                                <img draggable="false" class="fit-picture" src="{{ static('1flubeltje.jpg')}}" alt="no art of {{card.card.title}}" />
                                {% else %}
                                <img draggable="false" class="fit-picture" src="{{ static(card.card.artSource)}}" alt="art of {{card.card.title}}" />
                                {% endif %}
                            
                                <div class="smallCardInfo">
                                    {# <a href="{{returnURL}}card/{{ card.id }}/"> #}
                                        <p>
                                            {{ card.card.title }}
                                        </p>
                                        {#
                                    </a> #}
                                    <p class="cardType">
                                        {{["Intelligence","Speed","Visciousness","Resolve"][card.card.cardType]}}
                                    </p>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </li>
            {% endfor %}
            </ul>
        </li>
        </ul>
    <div class="deckHand">
        <p>Deck: {{ ownDeckCount }} | Hand: {{ handCards|length }}</p>
        <ul class="deck">
            {% if ownDeckCount > 0 %}
            {% for _ in ownDeckStack %}
            <li>
                {% if loop.last %}
                <form method="post" action="{{ actionUrl }}" class="cardActionForm">
                    {{ csrf_input }}
                    <input type="hidden" name="action" value="draw">
                    <button type="submit" class="card back draw" title="Draw card">Draw</button>
                </form>
                {% else %}
                <div class="card back">*</div>
                {% endif %}
            </li>
            {% endfor %}
            {% else %}
            <li>
                <div class="card back emptyDeck">
                    Empty
                </div>
            </li>
            {% endif %}
        </ul>
        <ul class="hand">
            {% if handCards %}
            {% for card in handCards %}
            <li class="card smallCard" draggable="true">
                <form method="post" action="{{ actionUrl }}" class="cardActionForm">
                    {{ csrf_input }}
                    <input type="hidden" name="action" value="play">
                    <input type="hidden" name="card_id" value="{{ card.id }}">
                    <input type="hidden" name="lane" value="{{ card.card.cardType + 1 }}">
                    <button type="submit" class="{{ card.cssClass }}" title="Play to {{ card.card.cardType }}">
                        {# <span class="rank">{{ card.card.cardType }}</span>
                        <span class="suit">{{ card.card.title }}</span> #}
                        {% if card.card.artSource == "" %}
                        <img draggable="false" class="fit-picture" src="{{ static('1flubeltje.jpg')}}" alt="no art of {{card.card.title}}" />
                        {% else %}
                        <img draggable="false" class="fit-picture" src="{{ static(card.card.artSource)}}" alt="art of {{card.card.title}}" />
                        {% endif %}
                    
                        <div class="smallCardInfo">
                            {# <a href="{{returnURL}}card/{{ card.id }}/"> #}
                                <p>
                                    {{ card.card.title }}
                                </p>
                                {#
                            </a> #}
                            <p class="cardType">
                                {{["Intelligence","Speed","Visciousness","Resolve"][card.card.cardType]}}
                            </p>
                        </div>
                    </button>
                </form>
            </li>
            {% endfor %}
            {% else %}
            <li>
                <div class="card back emptyHand">
                </div>
                </li>
                {% endif %}
                </ul>

        <form method="post" action="{{ actionUrl }}" class="cardActionForm">
            {{ csrf_input }}
            <input type="hidden" name="action" value="end_turn">
            <button type="submit" class="end-turn" title="End turn" autofocus>
                <span class="suit">End turn</span>
            </button>
        </form>
        </div>
        </div>

    <a href="{{ returnURL }}">back</a>
    <script type="module" src="{{ static('cardDragDrop.js')}}"></script>
    {% endblock %}
{# {% load static %} #}