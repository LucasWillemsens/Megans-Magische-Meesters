{% extends 'base.jinja2' %}

{% block extra_head %}
<link rel="stylesheet" href="{{ static('cards.css') }}">
{% endblock %}

{% block content %}
<div class="playerScreen playingCards fourColours rotateHand">
    <div class="players">
        <div class="title">
            <h1>{{ game.title }}</h1>
            <p>Round {{ game.roundNumber }}</p>
        </div>
        <div class="playerInfo">
            <h2>{{ player.name }}</h2>
            {% if player.profilePictureSource == "" %}
            <img class="fit-picture" src="{{ static('profile.jpg')}}" alt="{{player.name}}'s profile picture" />
            {% else %}
            <img class="fit-picture" src="{{ static('{{assetsDir}}+{{player.profilePictureSource}}')}}"
                alt="{{player.name}}'s profile picture" />
            {% endif %}
        </div>
    </div>

    {% if error_message != "" %}
    <div class="cards">
        <p><b>Action error:</b> {{ error_message }}</p>
    </div>
    {% endif %}

    {% if enemyBoards %}
    <ul class="enemyBoards basic-mat table">
        {% for enemy in enemyBoards %}
        <li class="enemyBoard">
            <h2>{{ enemy.participant.player.name }} board </h2>
            <p class="cardType">Deck: {{ enemy.deckCount }} | Hand: {{ enemy.handCount }}</p>
            <ul class="lanes">
                {% for lane in ownLaneRows %}
                <li class="lane {{lane.name}}">
                    {% if lane.cards %}
                    <ul class="cardRow" title="cards">
                        {% for card in lane.cards %}
                        <li>
                            <div class="card {{ card.cssClass }}" title="{{ lane.name }}">
                                <span class="rank">{{ card.rank }}</span>
                                <span class="suit">{{ card.title }}</span>
                            </div>
                            </li>
                            {% endfor %}
                    </ul>
                    <p> {{ lane.name }} </p>
                    <ul class="cardRow" title="trustedCards">
                        {% for card in lane.trustedCards %}
                        <li>
                            <div class="card {{ card.cssClass }}" title="{{ lane.name }}">
                                <span class="rank">{{ card.rank }}</span>
                                <span class="suit">{{ card.title }}</span>
                            </div>
                            </li>
                        {% endfor %}
                        </ul>
                        {% else %}
                        <p>
                            {{ lane.name }}
                        </p>
                    {% endif %}
                </li>
                {% endfor %}
                </ul>
            <div class="smallCardInfo">
            
            </div>
        </li>
        {% endfor %}
        </ul>
        {% else %}
        <p>No enemy participants loaded yet.</p>
        {% endif %}

    <ul class="basic-mat table">
        <li class="playerBoard ">
            <h2> {{ player.name }} board </h2>
            <ul class="lanes">
                {% for lane in ownLaneRows %}
                <li class="lane {{lane.name}}">
                    {% if lane.cards %}
                    <ul class="cardRow" title="cards">
                        {% for card in lane.cards %}
                        <li>
                            <div class="card {{ card.cssClass }}" title="{{ lane.name }}">
                                <span class="rank">{{ card.rank }}</span>
                                <span class="suit">{{ card.title }}</span>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                    <p> {{ lane.name }} </p>
                    <ul class="cardRow" title="trustedCards">
                        {% for card in lane.trustedCards %}
                        <li>
                            <div class="card {{ card.cssClass }}" title="{{ lane.name }}">
                                <span class="rank">{{ card.rank }}</span>
                                <span class="suit">{{ card.title }}</span>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                    {% else %}
                    <p>
                        {{ lane.name }}
                    </p>
                    {% endif %}
                </li>
            {% endfor %}
            </ul>
        </li>
        </ul>
    <div class="deckHand">
        <p>Deck: {{ ownDeckCount }} | Hand: {{ handCards|length }}</p>
        <ul class="deck">
            {% if ownDeckCount > 0 %}
            {% for _ in ownDeckStack %}
            <li>
                {% if loop.first %}
                <form method="post" action="{{ actionUrl }}" class="cardActionForm">
                    {{ csrf_input }}
                    <input type="hidden" name="action" value="draw">
                    <button type="submit" class="card back" title="Draw card">Draw</button>
                </form>
                {% else %}
                <div class="card back">*</div>
                {% endif %}
            </li>
            {% endfor %}
            {% else %}
            <li>
                <div class="card back">Empty</div>
            </li>
            {% endif %}
        </ul>
        <ul class="hand">
            {% if handCards %}
            {% for card in handCards %}
            <li>
                <form method="post" action="{{ actionUrl }}" class="cardActionForm">
                    {{ csrf_input }}
                    <input type="hidden" name="action" value="play">
                    <input type="hidden" name="card_id" value="{{ card.id }}">
                    <input type="hidden" name="lane" value="{{ card.lane }}">
                    <button type="submit" class="card {{ card.cssClass }}" title="Play to {{ card.laneName }}">
                        <span class="rank">{{ card.rank }}</span>
                        <span class="suit">{{ card.title }}</span>
                    </button>
                </form>
            </li>
            {% endfor %}
            {% else %}
            <li>
                <div class="card back">
                    {# No cards #}
                </div>
                </li>
                {% endif %}
                </ul>

        <form method="post" action="{{ actionUrl }}" class="cardActionForm">
            {{ csrf_input }}
            <input type="hidden" name="action" value="end_turn">
            <button type="submit" class="card joker" title="End turn">
                <span class="rank">!</span>
                <span class="suit">End turn</span>
            </button>
        </form>
        </div>
        </div>

    <a href="{{ returnURL }}">back</a>
    {% endblock %}